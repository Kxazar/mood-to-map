[Unit]
Description=Mood-to-Map hackathon app
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=codex
Group=codex
WorkingDirectory=/home/codex/mood-to-map
Environment=PORT=8080
Environment=KIMI_MODEL=moonshotai/kimi-k2-0905
Environment=NOUS_INFERENCE_BASE_URL=https://inference-api.nousresearch.com/v1
Environment=LLM_TIMEOUT_SECONDS=80
Environment=LLM_MAX_TOKENS=1200
Environment=LLM_POLISH_MAX_TOKENS=1200
Environment=LLM_DISCOVERY_MAX_TOKENS=1300
EnvironmentFile=-/home/codex/.hermes/.env
ExecStart=/usr/bin/python3 /home/codex/mood-to-map/server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
