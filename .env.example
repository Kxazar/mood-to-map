# Optional. Without a key the app runs in local deterministic mode.
# Preferred for the hackathon demo: Nous Portal API key.
NOUS_API_KEY=
NOUS_INFERENCE_BASE_URL=https://inference-api.nousresearch.com/v1

# Direct Moonshot/Kimi also works if you are not using Nous.
KIMI_API_KEY=

# Live-demo default. Change to moonshotai/kimi-k2.6 for the final quality proof if desired.
KIMI_MODEL=moonshotai/kimi-k2-0905
LLM_TIMEOUT_SECONDS=90
LLM_MAX_TOKENS=950
LLM_DISCOVERY_MAX_TOKENS=900

# Python server port.
PORT=8080
